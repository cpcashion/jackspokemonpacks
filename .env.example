# Get a free Gemini API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: eBay API keys for better results (https://developer.ebay.com)
EBAY_APP_ID=
EBAY_CERT_ID=

# Scan interval in minutes (default: 3)
SCAN_INTERVAL_MINUTES=3

# Dashboard port
PORT=3000
